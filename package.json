{
  "name": "recho-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"cd backend/gateway && node index.js\" \"vite\"",
    "dev:frontend": "vite",
    "dev:backend": "cd backend/gateway && node index.js",
    "build": "vue-tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/markdown-it": "^14.1.2",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.8"
  }
}
