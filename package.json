{
  "name": "recho-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:go",
    "dev:node": "concurrently -k -n gateway,vite -c cyan,magenta \"npm run dev:backend\" \"npm run dev:frontend:wait\"",
    "dev:go": "concurrently -k -n gateway,go-gateway,vite -c cyan,green,magenta \"npm run dev:backend:go\" \"npm run dev:go-backend\" \"npm run dev:frontend:go\"",
    "dev:frontend": "vite",
    "dev:frontend:wait": "node scripts/wait-for-url.mjs http://127.0.0.1:3000/health 30000 && vite",
    "dev:frontend:go": "node scripts/wait-for-url.mjs http://127.0.0.1:3000/health 30000 && node scripts/wait-for-url.mjs http://127.0.0.1:3001/health 30000 && vite",
    "dev:backend": "cd backend/gateway && npx tsx src/index.ts",
    "dev:backend:go": "cd backend/gateway && cross-env GO_GATEWAY_BASE_URL=http://127.0.0.1:3001 npx tsx src/index.ts",
    "dev:go-backend": "cd backend/go-gateway && cross-env PORT=3001 go run ./cmd/server",
    "build:go-backend": "cd backend/go-gateway && go build -o go-gateway ./cmd/server",
    "build": "vue-tsc -b && vite build",
    "postbuild": "node scripts/prepare-spa-fallbacks.mjs",
    "test": "vitest run",
    "test:contracts": "vitest run tests/go-owned-api-contract.test.ts tests/go-sidecar-contract.test.ts tests/go-sidecar-live-contract.test.ts",
    "credits:create": "cd backend/gateway && npm run credits:create --",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "@supabase/supabase-js": "^2.107.0",
    "@types/markdown-it": "^14.1.2",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "reka-ui": "^2.10.0",
    "shadcn-vue": "^2.7.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.8"
  }
}
