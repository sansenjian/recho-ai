# NVIDIA NIM（免费额度 40次/分钟/key，支持多 Key 逗号分隔以提升并发）
NVIDIA_API_KEY=your_nvidia_api_key_here
# NVIDIA_API_KEY=key1,key2,key3  ← 多 Key 示例
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# 可选：OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：Claude
ANTHROPIC_API_KEY=your_anthropic_key_here

# 可选：国产模型（Kimi/DeepSeek）
KIMI_API_KEY=your_kimi_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# MCP 服务（可选，按需配置）
TAVILY_API_KEY=your_tavily_key_here

# Supabase（数据库）
# publishable key 可以暴露给浏览器；service role key 只能放在后端，不能返回给前端。
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_IMAGE_BUCKET=recho-images

# Tencent COS（使用额度生成的私密图片文件）
# SecretId/SecretKey 只配置在后端/Render 环境变量，不能放到前端或仓库里。
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
# 必须使用腾讯云控制台显示的完整 Bucket 名，格式通常是 name-appid。
TENCENT_COS_BUCKET=recho-images-<appid>
TENCENT_COS_REGION=ap-guangzhou
# 可选：COS/CDN 自定义公有访问域名；不填时使用默认 COS 公有域名。
TENCENT_COS_PUBLIC_BASE_URL=

# 后台管理员。推荐使用 Supabase Auth 用户 ID；多个值用英文逗号分隔。
ADMIN_USER_IDS=
# 可选：也可以用邮箱配置管理员；多个值用英文逗号分隔。
ADMIN_USER_EMAILS=

# 网关配置
PORT=3000
CORS_ORIGIN=http://localhost:5173

# 生图服务（可选）
IMAGE_GEN_API_KEY=your_image_generation_key_here
IMAGE_GEN_BASE_URL=https://lucen.plus/v1
# 每张使用额度生成的图片消耗多少额度；未登录或额度不足时仍可免费生成并公开展示。
IMAGE_CREDIT_COST_PER_IMAGE=1
IMAGE_RESPONSES_MODEL=gpt-image-2
IMAGE_RESPONSES_IMAGE_MODEL=gpt-image-2
