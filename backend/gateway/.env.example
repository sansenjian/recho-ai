# NVIDIA NIM（免费额度 40次/分钟/key，支持多 Key 逗号分隔以提升并发）
NVIDIA_API_KEY=your_nvidia_api_key_here
# NVIDIA_API_KEY=key1,key2,key3  ← 多 Key 示例
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# 可选：OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：Claude
ANTHROPIC_API_KEY=your_anthropic_key_here

# 可选：国产模型（Kimi/DeepSeek）
KIMI_API_KEY=your_kimi_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# MCP 服务（可选，按需配置）
TAVILY_API_KEY=your_tavily_key_here

# Supabase（数据库）
# publishable key 可以暴露给浏览器；service role key 只能放在后端，不能返回给前端。
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=

# 网关配置
PORT=3000
CORS_ORIGIN=http://localhost:5173

# 生图服务（可选）
IMAGE_GEN_API_KEY=your_image_generation_key_here
IMAGE_GEN_BASE_URL=https://lucen.plus/v1
IMAGE_RESPONSES_MODEL=gpt-image-2
IMAGE_RESPONSES_IMAGE_MODEL=gpt-image-2
