{
  "name": "recho-ai-gateway",
  "version": "1.0.0",
  "description": "API gateway for AI chat aggregation",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "credits:create": "tsx src/scripts/create-credit-codes.ts",
    "normalize:image-prompts": "tsx src/scripts/normalize-image-prompts.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1066.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.107.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.85.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
